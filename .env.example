# ── Supabase — REQUIRED (auth, DB, RLS) ──────────────────────────────────────
# Dashboard → Settings → API  on https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key

# ── Anthropic — REQUIRED for chat (Opus 4.7) ─────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Zid OAuth — REQUIRED for /connect flow ───────────────────────────────────
# Partner Dashboard → Apps → Your app → OAuth
ZID_CLIENT_ID=
ZID_CLIENT_SECRET=
ZID_REDIRECT_URI=http://localhost:3000/api/auth/zid/callback
ZID_OAUTH_BASE_URL=https://oauth.zid.sa
ZID_API_BASE_URL=https://api.zid.sa

# ── App URL — where this app runs ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Optional: image generation (fal.ai) ──────────────────────────────────────
# FALAI_API_KEY=
